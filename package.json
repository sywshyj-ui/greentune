{
  "name": "greentune",
  "version": "1.0.0",
  "description": "GreenTune - 现代音乐播放器 (Spotify 绿色风格)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.greentune.app",
    "productName": "GreenTune",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!.git",
      "!.gitignore",
      "!README.md"
    ],
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "GreenTune-Portable.exe"
    },
    "extraMetadata": {
      "name": "greentune"
    }
  },
  "author": "小q",
  "license": "MIT",
  "dependencies": {
    "iconv-lite": "^0.6.3",
    "jsmediatags": "^3.9.7"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
