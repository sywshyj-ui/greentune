{
  "name": "greentune",
  "version": "1.0.0",
  "description": "浩哥的Music - 现代音乐播放器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.greentune.app",
    "productName": "浩哥的Music",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!.git",
      "!.gitignore",
      "!README.md",
      "!*.log",
      "!项目交接.md",
      "!generate-icon.js",
      "!build.log",
      "!electron.log",
      "!out.txt",
      "!err.txt"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "浩哥的Music-Portable.exe"
    },
    "extraMetadata": {
      "name": "greentune"
    }
  },
  "author": "小q",
  "license": "MIT",
  "dependencies": {
    "iconv-lite": "^0.6.3",
    "jsmediatags": "^3.9.7"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}